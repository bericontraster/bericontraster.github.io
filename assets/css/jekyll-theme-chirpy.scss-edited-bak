/* prettier-ignore */
@use 'main
{%- if jekyll.environment == 'production' -%}
  .bundle
{%- endif -%}
';

// ####################
// In Article Image CSS
// ####################

p img {
  border-radius: 15px;
  // border: 0.5px solid var(--img-border-color);
}

// Jetbrains Mono Font
@font-face {
  font-family: "JetBrains Mono";
  src: url("{{ '/assets/fonts/jetbrains-mono/JetBrainsMono-Regular.ttf' | relative_url }}") format("truetype");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

// Importing Inter Font
@font-face {
  font-family: "Inter";
  src: url("{{ '/assets/fonts/inter/Inter_24pt-Bold.ttf' | relative_url }}") format("truetype");
  font-weight: 700;
  font-style: normal;
  font-display: swap;
}

code, pre, kbd, samp {
  font-family: "JetBrains Mono", SFMono-Regular, Consolas, Menlo, monospace;
}

.highlight {
  padding-bottom: 0rem;
}

body {
  font-size: 1.07rem;
}

#post-list .card .card-body .card-text.content p {
  line-height: 1.2;
}

/* In-page content lists (posts/pages only) */
article .content p,
article .content li {
  font-size: 20px;
  line-height: 1.42;
}

h1 + .post-meta {
  font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
  font-weight: 600;
  font-size: 18px;
  line-height: 1.60rem;
}

header .post-desc {
  font-size: 20px;
  line-height: 1.42;
  font-weight: 400 !important;
}

h1, h2, h3, h4, h5, h6 {
  font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
  font-weight: bold;
}

tr {
  font-size: 1.10rem;
  font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
}

/* ===== Fix table horizontal scrolling ===== */
table {
  table-layout: fixed;
}

th,
td {
  white-space: normal !important;   /* allow wrapping */
  word-wrap: break-word;
  word-break: break-word;
}

/* Optional: improve readability */
td {
  vertical-align: top;
}

