html[data-mode="dark"] #sidebar {
  background-color: #000000;
}

html[data-mode="dark"] #sidebar #avatar {
  box-shadow: none !important;
  border: 0 !important;
  outline: 0 !important;
}

html[data-mode="dark"] #main-wrapper,
html[data-mode="dark"] #tail-wrapper > :not(script),
html[data-mode="dark"] #topbar-wrapper {
  background-color: #0a0a0a;
}

html[data-mode="dark"] .toc-border-cover,
html[data-mode="dark"] #toc-wrapper::before {
  background: #0a0a0a;
}

html[data-mode="dark"] #toc-wrapper::after {
  background: linear-gradient(transparent, #0a0a0a 70%);
}

html[data-mode="dark"] .post-preview {
  background: #111111;
  border: 0.5px solid #181616;
  box-shadow: none;
}

html[data-mode="dark"] .post-preview::before,
html[data-mode="dark"] #sidebar ul li.nav-item.active .nav-link {
  background-color: #043927;
}

@media (hover: hover) {
  html[data-mode="dark"] .nav-link {
    color: #ffffff;
  }
}

html[data-mode="light"] #main-wrapper,
html[data-mode="light"] #tail-wrapper > :not(script),
html[data-mode="light"] #topbar-wrapper {
  background-color: #ffffff;
}

html[data-mode="light"] #toc-wrapper::before,
html[data-mode="light"] .toc-border-cover {
  background: linear-gradient(#ffffff 50%, transparent);
}

html[data-mode="light"] #toc-wrapper::after {
  background: linear-gradient(transparent, #ffffff 70%);
}

html[data-mode="light"] .post-preview {
  background: #ffffff;
  border: 1px solid #e6e6e6;
  box-shadow: none;
}

html[data-mode="light"] .post-preview::before,
html[data-mode="light"] #sidebar ul li.nav-item.active .nav-link {
  background-color: #111111;
}

html[data-mode="light"] #sidebar ul li.nav-item.active .nav-link {
  color: #ffffff;
}

/* Unified rounded border and theme-aware color for code blocks */
html[data-mode="light"] div[class^="language-"],
html[data-mode="dark"] div[class^="language-"] {
  border: 1px solid var(--language-border-color);
  border-radius: 12px;
  overflow: hidden;
}

html[data-mode="light"] .highlight,
html[data-mode="light"] figure.highlight,
html[data-mode="light"] div[class^="language-"],
html[data-mode="light"] pre.highlight,
html[data-mode="light"] pre[class^="language-"] {
  background-color: var(--highlight-bg-color) !important;
  color: var(--code-color);
}

html[data-mode="dark"] .highlight,
html[data-mode="dark"] .highlight .w,
html[data-mode="dark"] figure.highlight,
html[data-mode="dark"] div[class^="language-"],
html[data-mode="dark"] pre.highlight,
html[data-mode="dark"] pre[class^="language-"] {
  background-color: var(--highlight-bg-color) !important;
  color: var(--code-color) !important;
}

html[data-mode="light"] .code-header,
html[data-mode="dark"] .code-header {
  background-color: var(--highlight-bg-color) !important;
  border-bottom: 1px solid var(--language-border-color);
}

html[data-mode="light"] :not(pre) > code,
html[data-mode="dark"] :not(pre) > code {
  background-color: var(--inline-code-bg);
  color: var(--code-color);
}
